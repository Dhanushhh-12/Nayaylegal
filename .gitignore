# =========================================================================
# NYAYA AI - GIT IGNORE RULES FOR SAFE GITHUB REPOSITORY HOSTING
# =========================================================================
# The following rules prevent committing heavy, local, or sensitive files
# to GitHub. DO NOT force-add or commit files matching these rules.
# =========================================================================

# 1. DEPENDENCIES & PACKAGES (Do not commit: too large)
# Exclude third-party libraries; these are rebuilt during deploy via 'npm install'.
node_modules/
/node_modules
/*/node_modules
/frontend/node_modules

# 2. BUILD PRODUCTION OUTPUTS (Do not commit: generated dynamically)
# Vite build bundles or transpiled output files should not be tracked.
dist/
/frontend/dist
build/

# 3. ENVIRONMENT SECRETS & API KEYS (CRITICAL - DO NOT COMMIT)
# Exclude local .env profiles to prevent leaking API Keys (e.g. GEMINI_API_KEY).
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 4. TEMPORARY RUNTIME LOGS (Do not commit: local session logs)
# Log files generated during development runs, compilation, or crashes.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
build.log

# 5. SYSTEM & OS CACHE FILES (Do not commit: generated by host OS)
.DS_Store
Thumbs.db
desktop.ini

# 6. EDITOR SETTINGS & WORKSPACE PREFERENCES (Do not commit: project-personal)
# Local configuration files from VS Code, IntelliJ, Eclipse, or Visual Studio.
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.project
.classpath
.settings/
